{
  "name": "@specd/studio-desktop",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "main": "dist/main/index.cjs",
  "scripts": {
    "build:main": "tsup --config tsup.main.config.ts",
    "build:preload": "tsup --config tsup.preload.config.ts",
    "build:renderer": "vite build -c vite.renderer.config.ts",
    "build:ui": "pnpm --filter @specd/ui build",
    "build": "pnpm rebuild:graph-sqlite-electron && pnpm build:ui && pnpm build:main && pnpm build:preload && pnpm build:renderer",
    "dev:renderer": "vite dev -c vite.renderer.config.ts",
    "rebuild:graph-sqlite-electron": "pnpm --filter @specd/code-graph-electron rebuild:vendored-sqlite-electron",
    "rebuild:graph-electron": "pnpm rebuild:graph-sqlite-electron",
    "prestart": "pnpm rebuild:graph-sqlite-electron",
    "start": "env ELECTRON_RUN_AS_NODE= electron .",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.renderer.json",
    "test": "vitest run --passWithNoTests",
    "lint": "eslint ."
  },
  "dependencies": {
    "@specd/code-graph-electron": "workspace:*",
    "@specd/client": "workspace:*",
    "@specd/sdk": "workspace:*",
    "@specd/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "electron": "^36.4.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.5",
    "vitest": "^3.0.0"
  }
}
