{
  "name": "@specd/studio-web",
  "version": "0.0.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "playwright:install": "playwright install chromium",
    "test:e2e": "node ../../dev/scripts/check-studio-e2e-ready.mjs && CI=1 playwright test",
    "test:e2e:headed": "node ../../dev/scripts/check-studio-e2e-ready.mjs && CI=1 playwright test --headed",
    "lint": "eslint ."
  },
  "dependencies": {
    "@specd/client": "workspace:*",
    "@specd/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.53.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "typescript": "^5.7.0",
    "vite": "^6.3.5",
    "vitest": "^3.0.0"
  }
}
