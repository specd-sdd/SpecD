{
  "name": "@specd/studio-web",
  "version": "0.1.0",
  "license": "MIT",
  "private": true,
  "type": "module",
  "main": "./dist/plugin.js",
  "exports": {
    ".": {
      "import": "./dist/plugin.js",
      "types": "./dist/plugin.d.ts"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && pnpm run build:plugin && node ./scripts/sync-plugin-ui-studio.mjs",
    "build:sync-plugin": "node ./scripts/sync-plugin-ui-studio.mjs",
    "build:plugin": "tsup src/plugin.ts --format esm --out-dir dist",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "playwright:install": "playwright install chromium",
    "test:e2e": "node ../../dev/scripts/check-studio-e2e-ready.mjs && CI=1 playwright test",
    "test:e2e:headed": "node ../../dev/scripts/check-studio-e2e-ready.mjs && CI=1 playwright test --headed",
    "lint": "eslint ."
  },
  "dependencies": {
    "@specd/client": "workspace:*",
    "@specd/plugin-manager": "workspace:*",
    "@specd/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@playwright/test": "1.53.2",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0",
    "vite": "^6.3.5",
    "vitest": "^3.0.0"
  }
}
