{
  "name": "show-spec-diff-during-validate",
  "createdAt": "2026-07-15T14:49:08.314Z",
  "description": "This change makes successful single-artifact spec validation show the merged inline diff directly when the target is an existing delta-backed scope: spec artifact, so reviewers can inspect risky removals or contract breakage without leaving changes validate. It also introduces a dedicated DiffGenerationError path in core preview/diff generation, keeps --all unchanged, and updates skill guidance so agents treat the inline diff as the immediate review surface while preserving spec-preview as the fallback and broader merged-review tool.",
  "schema": {
    "name": "schema-std",
    "version": 1
  },
