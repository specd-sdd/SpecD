{
  "name": "code-graph-electron",
  "createdAt": "2026-06-14T11:10:07.850Z",
  "updatedAt": "2026-06-15T07:17:42.808Z",
  "description": "Add an internal @specd/code-graph-electron workspace that keeps studio-desktop on the shared code-graph behavior while isolating Electron’s native SQLite runtime path from the standard CLI/API Node path. The change vendors and rebuilds better-sqlite3 specifically for Electron, rewires desktop local graph composition to consume the new package, and ensures desktop builds prepare the Electron-targeted sqlite runtime automatically.",
  "schema": {
    "name": "schema-std",
    "version": 1
