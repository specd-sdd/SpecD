  "files": [
    "dist/"
  ],
  "type": "module",
  "dependencies": {
    "@ast-grep/lang-go": "^0.0.5",
    "@ast-grep/lang-php": "^0.0.6",
    "@ast-grep/lang-python": "^0.0.5",
    "@ast-grep/napi": "^0.41.1",
    "@specd/core": "workspace:*",
    "better-sqlite3": "^12.8.0",
