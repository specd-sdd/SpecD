{
  "name": "@specd/cli",
  "version": "0.2.0",
  "license": "MIT",
  "private": false,
  "repository": "https://github.com/specd-sdd/SpecD",
  "homepage": "https://getspecd.dev",
  "files": [
    "dist/"
  ],
  "type": "module",
  "bin": {
    "specd": "./dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean",
    "dev": "tsup src/index.ts --format esm --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release:publish": "pnpm publish --access public"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@specd/code-graph": "workspace:*",
    "@specd/core": "workspace:*",
    "@specd/plugin-agent-claude": "workspace:*",
    "@specd/plugin-agent-codex": "workspace:*",
    "@specd/plugin-agent-copilot": "workspace:*",
    "@specd/plugin-agent-opencode": "workspace:*",
    "@specd/plugin-agent-standard": "workspace:*",
    "@specd/plugin-manager": "workspace:*",
    "@specd/schema-std": "workspace:*",
    "@toon-format/toon": "^2.1.0",
    "boxen": "^8.0.1",
    "chalk": "^5.6.2",
    "commander": "^13.0.0",
    "diff": "^8.0.4",
    "figlet": "^1.10.0",
    "nanospinner": "^1.2.2",
    "yaml": "^2.0.0"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/figlet": "^1.7.0"
  }
}
