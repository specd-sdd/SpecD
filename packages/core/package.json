{
  "name": "@specd/core",
  "version": "0.2.0",
  "license": "MIT",
  "private": false,
  "repository": "https://github.com/specd-sdd/SpecD",
  "homepage": "https://getspecd.dev",
  "type": "module",
  "files": [
    "dist/"
  ],
  "dependencies": {
    "diff": "^8.0.4",
    "ignore": "^7.0.0",
    "mdast-util-from-markdown": "^2.0.3",
    "mdast-util-to-markdown": "^2.1.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "yaml": "^2.0.0",
    "zod": "^3.25.76"
  },
  "exports": {
    ".": {
      "import": "./dist/public.js",
      "types": "./dist/public.d.ts"
    },
    "./ports": {
      "import": "./dist/ports.js",
      "types": "./dist/ports.d.ts"
    },
    "./extensions": {
      "import": "./dist/extensions.js",
      "types": "./dist/extensions.d.ts"
    },
    "./internal": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/public.ts src/ports.ts src/extensions.ts src/index.ts --format esm --dts --clean",
    "dev": "tsup src/public.ts src/ports.ts src/extensions.ts src/index.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release:publish": "pnpm publish --access public",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@types/diff": "^8.0.0"
  }
}
