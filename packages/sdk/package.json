{
  "name": "@specd/sdk",
  "version": "0.1.0",
  "license": "MIT",
  "private": false,
  "repository": "https://github.com/specd-sdd/SpecD",
  "homepage": "https://getspecd.dev",
  "files": [
    "dist/"
  ],
  "type": "module",
  "dependencies": {
    "@specd/code-graph": "workspace:*",
    "@specd/core": "workspace:*"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./ports": {
      "import": "./dist/ports.js",
      "types": "./dist/ports.d.ts"
    },
    "./extensions": {
      "import": "./dist/extensions.js",
      "types": "./dist/extensions.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/ports.ts src/extensions.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/ports.ts src/extensions.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release:publish": "pnpm publish --access public",
    "lint": "eslint src test"
  }
}
